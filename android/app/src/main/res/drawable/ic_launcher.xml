<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/black" />
    <item android:width="96dp" android:height="96dp" android:gravity="center">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="315"
                android:startColor="#6C63FF"
                android:endColor="#FF6B6B" />
        </shape>
    </item>
    <item android:width="64dp" android:height="64dp" android:gravity="center">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>
    <item android:width="52dp" android:height="52dp" android:gravity="center">
        <bitmap
            android:src="@drawable/quiz_vance_launcher_mark"
            android:gravity="center" />
    </item>
</layer-list>
